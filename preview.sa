class Vector
  function _init(x, y)
    this.x = x; this.y = y
  end
  function _str
    return "<${this.x}, ${this.y}>"
  end
  function +(other)
    return Vector(this.x + other.x,
                  this.y + other.y)
  end
end

if _name == "@main"
  # initialize a new vector object
  v1 = Vector(1, 2);

  # initialize a new vector object
  v2 = Vector(3, 4);

  # add two vector
  v3 = v1 + v2

  # print v3, result is "<4, 6>"
  print(str(v3))
end